{
  "name": "AnkitCAP",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "db":{
        "kind":"sqlite",
        "credentials":{
          "url":"db-sqlite"
        }
      },
      "auth": "dummy",
      "messaging": {
        "kind": "enterprise-messaging"
      },
      "connectivity": true,
      "destinations": true,
      "html5-repo": true,
      "application-logging": true
    }
  }
}
